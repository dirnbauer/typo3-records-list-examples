# =============================================================================
# Records List Examples - Additional view types for the TYPO3 Records module
#
# These view types are available on ALL pages by default.
# To restrict a view type to specific pages, use TSconfig conditions:
#
#   [page["uid"] == 42]
#       mod.web_list.viewMode.allowed = list,timeline
#       mod.web_list.viewMode.default = timeline
#   [end]
# =============================================================================

mod.web_list.viewMode {

    # Make all example views available alongside the built-in ones
    allowed = list,grid,compact,teaser,timeline,catalog,addressbook,eventlist,gallery,dashboard

    # -------------------------------------------------------------------------
    # Timeline View
    # Vertical timeline with date markers. Custom template using the
    # shared records_list_types heading/systematic + TYPO3 core sanitization.
    # Best for: events, changelog, history, milestones
    # -------------------------------------------------------------------------
    types.timeline {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.timeline
        icon = actions-calendar
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.timeline.description
        template = TimelineView
        templateRootPath = EXT:records_list_examples/Resources/Private/Backend/Templates/
        partialRootPath = EXT:records_list_examples/Resources/Private/Backend/Partials/
        css = EXT:records_list_examples/Resources/Public/Css/timeline.css
        displayColumns = label,datetime,teaser
        columnsFromTCA = 0
        itemsPerPage = 50
    }

    # -------------------------------------------------------------------------
    # Catalog View
    # Large image cards with overlay title. Custom template using the
    # shared records_list_types heading/systematic + TYPO3 core sanitization.
    # Best for: products, portfolio, team members, media assets
    # -------------------------------------------------------------------------
    types.catalog {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.catalog
        icon = actions-viewmode-tiles
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.catalog.description
        template = CatalogView
        templateRootPath = EXT:records_list_examples/Resources/Private/Backend/Templates/
        partialRootPath = EXT:records_list_examples/Resources/Private/Backend/Partials/
        css = EXT:records_list_examples/Resources/Public/Css/catalog.css
        displayColumns = label,teaser
        columnsFromTCA = 0
        itemsPerPage = 24
    }

    # -------------------------------------------------------------------------
    # Address Book
    # Dense table with fixed contact columns. Reuses built-in CompactView.
    # Best for: contacts, members, employees, organizations
    # -------------------------------------------------------------------------
    types.addressbook {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.addressbook
        icon = actions-user
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.addressbook.description
        template = CompactView
        css = EXT:records_list_types/Resources/Public/Css/compact-view.css
        displayColumns = label,teaser
        columnsFromTCA = 0
        itemsPerPage = 500
    }

    # -------------------------------------------------------------------------
    # Event List
    # Date-focused teaser cards. Reuses built-in TeaserView.
    # Best for: events, conferences, meetups, deadlines
    # -------------------------------------------------------------------------
    types.eventlist {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.eventlist
        icon = actions-clock
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.eventlist.description
        template = TeaserView
        css = EXT:records_list_types/Resources/Public/Css/teaser-view.css
        displayColumns = label,datetime,teaser
        columnsFromTCA = 0
        itemsPerPage = 30
    }

    # -------------------------------------------------------------------------
    # Photo Gallery
    # Image-heavy grid with minimal text. Reuses built-in GridView.
    # Best for: images, media files, artwork, screenshots
    # -------------------------------------------------------------------------
    types.gallery {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.gallery
        icon = actions-image
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.gallery.description
        template = GridView
        css = EXT:records_list_types/Resources/Public/Css/grid-view.css
        displayColumns = label
        columnsFromTCA = 0
        itemsPerPage = 48
    }

    # -------------------------------------------------------------------------
    # Dashboard
    # Card grid with editor-selected columns. Reuses built-in GridView.
    # Best for: editorial overview, content dashboard, record management
    # -------------------------------------------------------------------------
    types.dashboard {
        label = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.dashboard
        icon = content-widget-list
        description = LLL:EXT:records_list_examples/Resources/Private/Language/locallang.xlf:viewMode.dashboard.description
        template = GridView
        css = EXT:records_list_types/Resources/Public/Css/grid-view.css
        columnsFromTCA = 1
        itemsPerPage = 20
    }
}
